{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4-5",
  "small_model": "anthropic/claude-haiku-4-5",
  "instructions": [
    "~/.config/opencode/AGENTS.md"
  ],
  "permission": {
    "bash": {
      "*": "ask",
      "git *": "allow",
      "git push * origin main": "deny",
      "git push * origin master": "deny",
      "git push * origin develop": "deny",
      "git reset --hard *": "deny",
      "git clean -fd*": "deny",
      "git clean -fx*": "deny",
      "git push * --force": "deny",
      "git push * --force*": "deny",
      "git branch -D *": "deny",
      "rm -rf /": "deny",
      "rm -rf /*": "deny",
      "rm -rf /.*": "deny",
      "rm -rf ~": "deny",
      "rm -rf ~/*": "deny",
      "rm -rf node_modules": "ask",
      "rm -rf vendor": "ask",
      "rm -rf .git": "deny",
      "DROP DATABASE *": "deny",
      "DROP SCHEMA *": "deny",
      "TRUNCATE TABLE *": "deny",
      "DELETE FROM *": "ask",
      "DELETE FROM * WHERE *": "allow"
    },
    "read": {
      "*": "allow",
      "**/.env*": "deny",
      "**/.aws/credentials": "deny",
      "**/.aws/config": "deny",
      "**/.ssh/id_*": "deny",
      "**/.ssh/authorized_keys": "deny",
      "**/.ssh/known_hosts": "deny",
      "**/.ssh/config": "deny",
      "**/kubeconfig": "deny",
      "**/terraform.tfstate*": "deny"
    },
    "edit": {
      "*": "allow",
      "**/.env*": "deny",
      "**/.aws/credentials": "deny",
      "**/.aws/config": "deny",
      "**/.ssh/id_*": "deny",
      "**/.ssh/authorized_keys": "deny",
      "**/.ssh/known_hosts": "deny",
      "**/.ssh/config": "deny",
      "**/kubeconfig": "deny",
      "**/terraform.tfstate*": "deny"
    }
  },
  "command": {
    "security-audit": {
      "description": "Comprehensive security audit covering OWASP top 10, injection, auth, data exposure, dependencies, and infrastructure.",
      "model": "anthropic/claude-opus-4-5",
      "template": "Perform a comprehensive security audit. Check OWASP Top 10, injection vulnerabilities, auth patterns, data exposure, dependency security, and infrastructure configuration. Provide severity ratings and remediation steps for each finding. Full reference: ~/.config/opencode/commands/security-audit.md"
    },
    "performance-review": {
      "description": "Analyze code for performance issues including N+1 queries, bundle size, caching, and infrastructure bottlenecks.",
      "model": "anthropic/claude-opus-4-5",
      "template": "Analyze code for performance issues. Check for: N+1 queries, bundle size, caching strategy, infrastructure bottlenecks, memory leaks, slow queries, unnecessary re-renders, large file transfers, concurrency issues, and API response times. Provide concrete before/after optimization suggestions. Full reference: ~/.config/opencode/commands/performance-review.md"
    },
    "ship": {
      "description": "Create feature branch from staged/unstaged changes, raise a PR against default branch, squash merge it, delete the branch, and return to default branch with latest pull.",
      "model": "anthropic/claude-haiku-4-5",
      "template": "Complete git workflow: branch, commit, PR, squash merge, cleanup. Validate working state, create feature branch from changes, commit conventionally, push, create PR via gh, squash merge, delete branch, pull latest. Print success summary with PR URL and commit SHA. Full reference: ~/.config/opencode/commands/ship.md"
    },
    "obs-setup": {
      "description": "Research a content niche and generate a fully wired OBS scene collection with scenes, hotkeys, mic/camera/audio setup tailored to top creators in that field, then run the setup.",
      "model": "anthropic/claude-sonnet-4-5",
      "template": "Set up OBS for a content niche. Gather niche/platform/brand from user, research top creators for color palettes and scene layouts, generate a scene JS file at obs/scenes/<slug>.js using the obs/utils.js API, wire dynamic loading in obs/setup.js, add hotkeys, then run: cd obs && node setup.js --profile <slug>. Full reference: ~/.config/opencode/commands/obs-setup.md"
    }
  },
  "mcp": {
    "obs": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "obs-mcp@latest"
      ],
      "enabled": true,
      "env": {
        "OBS_WEBSOCKET_URL": "ws://localhost:4455"
      }
    },
    "omnisocials": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@omnisocials/mcp-server"
      ],
      "enabled": true,
      "env": {
        "OMNISOCIALS_API_KEY": "${OMNISOCIALS_API_KEY}"
      }
    }
  }
}
