{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/prevent-push-protected-branches.sh"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/prevent-read-env.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash -c '\"/Users/rckstrbhushan/.nvm/versions/node/v25.4.0/bin/node\" \"$(ls -td ~/.claude/plugins/cache/claude-hud/claude-hud/*/ 2>/dev/null | head -1)dist/index.js\"'"
  },
  "enabledPlugins": {
    "claude-mem@thedotmack": true,
    "claude-code-setup@claude-plugins-official": true,
    "frontend-design@claude-code-plugins": true,
    "laravel-boost@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "claude-hud@claude-hud": true
  },
  "voiceEnabled": true
}
