{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/prevent-push-protected-branches.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/prevent-destructive-git.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/prevent-rm-dangerous.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/prevent-dangerous-sql.sh"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/prevent-read-env.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/prevent-write-credentials.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/prevent-write-credentials.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "codegraph mark-dirty",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "codegraph sync-if-dirty"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash -c '\"/Users/rckstrbhushan/.nvm/versions/node/v25.4.0/bin/node\" \"$(ls -td ~/.claude/plugins/cache/claude-hud/claude-hud/*/ 2>/dev/null | head -1)dist/index.js\"'"
  },
  "enabledPlugins": {
    "claude-mem@thedotmack": true,
    "frontend-design@claude-code-plugins": true,
    "laravel-boost@claude-plugins-official": true,
    "claude-hud@claude-hud": true
  },
  "permissions": {
    "allow": [
      "mcp__codegraph__codegraph_search",
      "mcp__codegraph__codegraph_context",
      "mcp__codegraph__codegraph_callers",
      "mcp__codegraph__codegraph_callees",
      "mcp__codegraph__codegraph_impact",
      "mcp__codegraph__codegraph_node",
      "mcp__codegraph__codegraph_status",
      "mcp__codegraph__codegraph_files"
    ]
  },
  "extraKnownMarketplaces": {},
  "effortLevel": "high",
  "model": "claude-opus-4-6",
  "voiceEnabled": true
}
