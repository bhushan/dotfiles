{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/prevent-push-protected-branches.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/prevent-destructive-git.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/prevent-rm-dangerous.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/prevent-dangerous-sql.sh"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/prevent-read-env.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/prevent-write-credentials.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/prevent-write-credentials.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash -c '\"/Users/rckstrbhushan/.nvm/versions/node/v25.4.0/bin/node\" \"$(ls -td ~/.claude/plugins/cache/claude-hud/claude-hud/*/ 2>/dev/null | head -1)dist/index.js\"'"
  },
  "enabledPlugins": {
    "claude-mem@thedotmack": false,
    "claude-code-setup@claude-plugins-official": false,
    "frontend-design@claude-code-plugins": true,
    "laravel-boost@claude-plugins-official": true,
    "code-review@claude-plugins-official": false,
    "claude-hud@claude-hud": true,
    "ui-ux-pro-max@ui-ux-pro-max-skill": false,
    "superpowers@claude-plugins-official": false
  },
  "extraKnownMarketplaces": {
    "ui-ux-pro-max-skill": {
      "source": {
        "source": "github",
        "repo": "nextlevelbuilder/ui-ux-pro-max-skill"
      }
    }
  },
  "voiceEnabled": true
}
