#!/usr/bin/env bash

set -e

DOTFILES="$HOME/code/dotfiles"

step() { echo ""; echo "==> $*"; }

# ── Xcode Command Line Tools ───────────────────────────────────────────
if ! xcode-select -p &>/dev/null; then
  echo "==> Installing Xcode Command Line Tools..."
  xcode-select --install
  echo ""
  echo "    Xcode Command Line Tools are installing."
  echo "    Re-run this script once they finish."
  exit 1
fi

# ── Homebrew ───────────────────────────────────────────────────────────
if [[ ! -x /opt/homebrew/bin/brew ]] && [[ ! -x /usr/local/bin/brew ]]; then
  step "Installing Homebrew..."
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:$PATH"

# ── Dotfiles must be cloned first ─────────────────────────────────────
if [[ ! -d "$DOTFILES" ]]; then
  echo ""
  echo "  Dotfiles not found at $DOTFILES."
  echo "  Clone your repo there first:"
  echo ""
  echo "    git clone <your-repo-url> $DOTFILES"
  echo ""
  exit 1
fi

cd "$DOTFILES"

# ── Run setup scripts ──────────────────────────────────────────────────
source "$DOTFILES/scripts/packages.sh"
source "$DOTFILES/scripts/links.sh"
source "$DOTFILES/scripts/apps.sh"

echo ""
echo "==> All done. Open Kitty to start."
